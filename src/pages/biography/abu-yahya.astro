  <Header />
  <div class="biography-page theme-green fade-in">
    <main class="single-layout"> <div class="biography-page theme-green fade-in"> <!-- Header Hero Banner --> <section class="bio-hero"> <div class="bio-hero-overlay"></div> <div class="bio-hero-container"> <h1 class="bio-title font-sans">سيرة الشيخ الشهيد أبي يحيى الليبي</h1> <p class="bio-name">حسن محمد قائد (تقبله الله في الشهداء)</p> <p class="bio-subtitle">من الميلاد إلى الاستشهاد</p> <div class="bio-cover-side"><img src="/media/cover_1.png" alt="غلاف مجموع أعمال الشيخ أبي يحيى الليبي" class="bio-cover-img" /></div> </div> </section> <!-- Brief Overview Cards --> <section class="bio-overview"> <div class="overview-grid"> <div class="overview-card"> <div class="overview-icon"> <svg fill="none" height="24" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24" width="24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg> </div> <h4>الاسم الكامل</h4> <p>حسن محمد قائد (أبو يحيى)</p> </div> <div class="overview-card"> <div class="overview-icon"> <svg fill="none" height="24" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24" width="24"><rect height="18" rx="2" ry="2" width="18" x="3" y="4"></rect><line x1="16" x2="16" y1="2" y2="6"></line><line x1="8" x2="8" y1="2" y2="6"></line><line x1="3" x2="21" y1="10" y2="10"></line></svg> </div> <h4>الميلاد والنشأة</h4> <p>٦ شعبان ١٣٨٢ هـ (قرية تساوة - الصحراء الليبية)</p> </div> <div class="overview-card"> <div class="overview-icon"> <svg fill="none" height="24" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24" width="24"><path d="M12 2L2 7l10 5 10-5-10-5z"></path><path d="M2 17l10 5 10-5"></path><path d="M2 12l10 5 10-5"></path></svg> </div> <h4>التخصص الشرعي</h4> <p>أصول الفقه، علوم اللغة، والفقه المقارن (دراسة محظرية بشنقيط)</p> </div> <div class="overview-card"> <div class="overview-icon"> <svg fill="none" height="24" stroke="currentColor" stroke-width="2" viewbox="0 0 24 24" width="24"><circle cx="12" cy="5" r="3"></circle><line x1="12" x2="12" y1="22" y2="8"></line><path d="M5 12H2a10 10 0 0 0 20 0h-3"></path></svg> </div> <h4>الوفاة والارتقاء</h4> <p>١٤٣٣ هـ / ٢٠١٢ م (وزيرستان - باكستان)</p> </div> </div> </section>       <!-- Historical Photo Gallery Section -->
