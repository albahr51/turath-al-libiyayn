  /* Plyr custom theme overrides */
  .plyr--audio .plyr__controls {
    background: var(--card-bg);
    border-top: 1px solid var(--border-color);
  }
  .plyr--video .plyr__controls {
    background: linear-gradient(transparent, rgba(0,0,0,0.85));
  }
  .plyr__control--overlaid {
    background: var(--primary-color);
  }
  .plyr--video .plyr__control--overlaid {
    background: var(--primary-color);
  }
  .plyr__control--overlaid:hover {
    background: var(--primary-light) !important;
  }
  .plyr--full-ui input[type=range] {
    color: var(--primary-color);
  }
  .plyr--video .plyr__control.plyr__tab-focus,
  .plyr--video .plyr__control:hover,
  .plyr--video .plyr__control[aria-expanded=true] {
    background: var(--primary-color);
  }
  .plyr__menu__container .plyr__control[role=menuitemradio][aria-checked=true]::before {
    background: var(--primary-color);
  }
  :root {
    --plyr-color-main: var(--primary-color);
  }
  [data-theme="dark"] {
    --plyr-video-control-background-hover: var(--primary-color);
    --plyr-audio-control-background-hover: var(--primary-color);
  }
</style>

<script>
  import Plyr from 'plyr';

  document.addEventListener('DOMContentLoaded', () => {
    const plyrInstances = new Map();

    const plyrConfig = {
      controls: [
        'play-large', 'restart', 'rewind', 'play', 'fast-forward',
        'progress', 'current-time', 'duration',
        'mute', 'volume', 'captions', 'settings', 'download', 'pip', 'airplay', 'fullscreen'
      ],
      settings: ['speed', 'quality'],
      speed: { selected: 1, options: [0.5, 0.75, 1, 1.25, 1.5, 1.75, 2] },
      seekTime: 10,
      keyboard: { focused: true, global: true },
      tooltips: { controls: true, seek: true },
      invertTime: false,
      toggleInvert: false,
      resetOnEnd: true,
      displayDuration: true
    };

    function initPlayers(container = document) {
      container.querySelectorAll('audio.plyr-audio, video.plyr-video').forEach((el) => {
        if (el.id && plyrInstances.has(el.id)) return;
        const id = el.id || `plyr-${Math.random().toString(36).slice(2)}`;
        el.id = id;
        const player = new Plyr(el, plyrConfig);
        plyrInstances.set(id, player);
      });
    }

    initPlayers();

    // Playlist select – switch audio source on change
    document.querySelectorAll('[data-playlist-select]').forEach((select) => {
      const wrapper = select.parentElement;
      if (!wrapper) return;
      const audioEl = wrapper.querySelector('[data-playlist-player]');
      if (!audioEl) return;
      const id = audioEl.id;
      
      select.addEventListener('change', () => {
        const src = select.value;
        if (id && plyrInstances.has(id)) {
          const player = plyrInstances.get(id);
          player.source = {
            type: 'audio',
            sources: [{ src, type: 'audio/mp3' }]
          };
          player.play();
        } else {
          audioEl.src = src;
          audioEl.load();
          audioEl.play();
        }
      });
    });

    // Filter controls
    const filterBtns = document.querySelectorAll('.filter-btn');
    const typeFilterBtns = document.querySelectorAll('.type-filter-btn');
    const mediaCards = document.querySelectorAll('.media-card');
    const emptyState = document.getElementById('media-empty-state');
    const searchInput = document.getElementById('media-search');
    const searchCount = document.getElementById('search-count');
    
    let currentAuthor = 'all';
    let currentType = 'all';
    let searchTerm = '';
    let debounceTimer = null;
    
    function normalize(str) {
      return str.replace(/[إأآا]/g, 'ا').replace(/[يى]/g, 'ي').replace(/[ؤئء]/g, 'ء').replace(/[ة]/g, 'ه').trim().toLowerCase();
    }
    
    function applyFilters() {
      let visibleCount = 0;
      mediaCards.forEach((card) => {
        const cardAuthor = card.getAttribute('data-author');
        const hasAudio = card.getAttribute('data-has-audio') === 'true';
        const hasVideo = card.getAttribute('data-has-video') === 'true';
        const title = card.querySelector('.media-card-title')?.textContent || '';
        
        const authorMatch = (currentAuthor === 'all' || cardAuthor === currentAuthor);
        let typeMatch = false;
        if (currentType === 'all') typeMatch = true;
        else if (currentType === 'audio' && hasAudio) typeMatch = true;
        else if (currentType === 'video' && hasVideo) typeMatch = true;
        
        const searchMatch = !searchTerm || normalize(title).includes(searchTerm);
        
        const show = authorMatch && typeMatch && searchMatch;
        card.style.display = show ? 'flex' : 'none';
        if (show) visibleCount++;
      });
      if (emptyState) emptyState.style.display = visibleCount === 0 ? 'block' : 'none';
      if (searchCount) searchCount.textContent = visibleCount > 0 ? `${visibleCount} نتيجة` : '';
    }
    
    filterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentAuthor = btn.getAttribute('data-filter') || 'all';
        applyFilters();
      });
    });
    
    typeFilterBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        typeFilterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentType = btn.getAttribute('data-type') || 'all';
        applyFilters();
      });
    });
    
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
          searchTerm = normalize(searchInput.value);
          applyFilters();
        }, 150);
      });
    }
  });
</script>
