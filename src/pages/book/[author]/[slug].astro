---
import { getCollection, render } from 'astro:content';
import BookLayout from '../../../layouts/BookLayout.astro';
import mediaMappings from '../../../data/media-mappings.json';
import printMappings from '../../../data/print-mappings.json';
import '../../../styles/book-page.css';
import 'plyr/dist/plyr.css';

function stripDiacritics(s: string): string {
  return s.replace(/[\u064B-\u065F\u0670\u0610-\u061A]/g, '');
}

export async function getStaticPaths() {
  const entries = await getCollection('books');
  return entries.map(entry => {
    return {
      params: { 
        author: entry.data.author, 
        slug: entry.data.slug 
      },
      props: { entry }
    };
  });
}

// Build order→PDF slug lookup for each author
const allEntries = await getCollection('books');
const orderToPdf: Record<string, [number, string][]> = {};
for (const author of ['abu-yahya', 'atiyatullah']) {
  const pm = (printMappings as Record<string, Record<string, string[]>>)[author];
  if (!pm) continue;
  const list: [number, string][] = [];
  for (const [page, slugs] of Object.entries(pm)) {
    const match = allEntries.find(e => e.data.author === author && e.data.slug === slugs[0]);
    if (match) list.push([match.data.order, slugs[0]]);
  }
  list.sort((a, b) => a[0] - b[0]);
  orderToPdf[author] = list;
}

function findPdfSlug(order: number, author: string, slug: string): string {
  const pm = (printMappings as Record<string, Record<string, string[]>>)[author];
  // Direct lookup
  const pageNum = Object.entries(pm || {}).find(([, slugs]) => slugs.includes(slug))?.[0];
  if (pageNum) return pm[pageNum][0];
  // Fallback: find closest order
  const ranges = orderToPdf[author] || [];
  let best = slug;
  for (const [o, pdfSlug] of ranges) {
    if (o <= order) best = pdfSlug;
  }
  return best;
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const authorTitles = {
  'abu-yahya': {
    brandTitle: "مجموع أعمال الشيخ أبي يحيى الليبي",
    brandSubtitle: "الأعمال الكاملة",
    themeClass: "theme-green"
  },
  'atiyatullah': {
    brandTitle: "مجموع أعمال الشيخ عطية الله الليبي",
    brandSubtitle: "الأعمال الكاملة",
    themeClass: "theme-gold"
  }
}[entry.data.author];

const printPdfSlug = findPdfSlug(entry.data.order, entry.data.author, entry.data.slug);
const printLink = `/media/extracted/${entry.data.author}/${printPdfSlug}.pdf`;

// Author media folders
const authorFolders = {
  'abu-yahya': 'أبو يحيى الليبي؛ رحمه الله',
  'atiyatullah': 'عطية الله الليبي؛ رحمه الله'
};

// Fetch media info from mapping json
const rawMedia = mediaMappings[entry.data.slug as keyof typeof mediaMappings] as {
  title: string;
  audio?: string;
  audios?: string[];
  video?: string;
} | undefined;

const folder = authorFolders[entry.data.author as keyof typeof authorFolders] || '';
const pageMedia = rawMedia ? {
  ...rawMedia,
  audio: rawMedia.audio ? `${folder}/${rawMedia.audio}` : undefined,
  audios: rawMedia.audios ? rawMedia.audios.map(p => `${folder}/${p}`) : undefined,
  video: rawMedia.video ? `${folder}/${rawMedia.video}` : undefined,
  title: rawMedia.title
} : undefined;
---

<BookLayout 
  title={`${entry.data.title} | ${authorTitles.brandTitle}`}
  description={`${entry.data.title} - ${authorTitles.brandTitle}`}
  author={entry.data.author}
  currentSlug={entry.data.slug}
  themeClass={authorTitles.themeClass}
  brandTitle={authorTitles.brandTitle}
  brandSubtitle={authorTitles.brandSubtitle}
>
  {pageMedia && (() => {
    const hasSingleAudio = !!pageMedia.audio;
    const hasMultipleAudios = !!(pageMedia.audios && pageMedia.audios.length > 0);
    if (!hasSingleAudio && !hasMultipleAudios && !pageMedia.video) return null;
    return (
    <div class="chapter-media-container" data-pagefind-ignore="">
      <div class="media-header">
        <span class="media-icon">🎬</span>
        <span class="media-header-title">المواد الصوتية والمرئية المصاحبة</span>
      </div>
      <div class="media-body">
        {hasMultipleAudios && (
          <div class="media-item-wrapper">
            <h4 class="media-item-title">{pageMedia.title}</h4>
            <div class="playlist-extra">
              <select class="playlist-select" data-playlist-select>
                {pageMedia.audios!.map((audioFile, i) => (
                  <option value={`/media/${audioFile}`}>المقطع {i + 1}</option>
                ))}
              </select>
              <div class="local-audio-wrapper">
                <audio class="local-audio-player plyr-audio" preload="metadata" data-playlist-player>
                  <source src={`/media/${pageMedia.audios![0]}`} />
                  متصفحك لا يدعم تشغيل هذا الملف الصوتي.
                </audio>
              </div>
            </div>
          </div>
        )}
        {hasSingleAudio && (
          <div class="media-item-wrapper">
            <h4 class="media-item-title">{pageMedia.title}</h4>
            <div class="local-audio-wrapper">
              <audio class="local-audio-player plyr-audio" preload="metadata">
                <source src={`/media/${pageMedia.audio}`} />
                متصفحك لا يدعم تشغيل هذا الملف الصوتي.
              </audio>
            </div>
          </div>
        )}
        {pageMedia.video && (
          <div class="media-item-wrapper">
            <h4 class="media-item-title">{pageMedia.title}</h4>
            <div class="local-video-wrapper">
              <video class="local-video-player plyr-video" preload="metadata">
                <source src={`/media/${pageMedia.video}`} type="video/mp4" />
                متصفحك لا يدعم تشغيل هذا الفيديو.
              </video>
            </div>
          </div>
        )}
      </div>
    </div>
    );
  })()}
  <div class="chapter-download-bar">
    <a href={printLink} class="btn-chapter-download" title="تحميل الكتاب مفردًا">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
        <polyline points="7 10 12 15 17 10"></polyline>
        <line x1="12" y1="15" x2="12" y2="3"></line>
      </svg>
      <span>تحميل الكتاب مفردًا</span>
    </a>
  </div>
  <Content />
</BookLayout>

<style>
  .chapter-download-bar {
    display: flex;
    justify-content: flex-start;
    margin-bottom: 20px;
  }
  .btn-chapter-download {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: 8px;
    background-color: var(--accent-color);
    color: #fff !important;
    font-size: .9rem;
    font-weight: 700;
    text-decoration: none;
    transition: all var(--transition-fast);
  }
  .btn-chapter-download:hover {
    opacity: .85;
    transform: translateY(-2px);
  }

  .playlist-extra {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .playlist-select {
    width: 100%;
    padding: 6px 10px;
    border-radius: 6px;
    border: 1px solid var(--border-color);
    background: var(--bg-color);
    color: var(--text-color);
    font-size: 0.85rem;
    font-weight: 600;
    cursor: pointer;
  }

  /* Plyr custom theme overrides */
  :root {
    --plyr-color-main: var(--primary-color);
  }
  .plyr--audio .plyr__controls {
    background: var(--card-bg);
    border-top: 1px solid var(--border-color);
  }
  .plyr__control--overlaid {
    background: var(--primary-color);
  }
  .plyr__control--overlaid:hover {
    background: var(--primary-light) !important;
  }
  .plyr--full-ui input[type=range] {
    color: var(--primary-color);
  }
</style>

<script>
  import Plyr from 'plyr';

  document.addEventListener('DOMContentLoaded', () => {
    const plyrInstances = new Map();

    const plyrConfig = {
      controls: [
        'play-large', 'restart', 'rewind', 'play', 'fast-forward',
        'progress', 'current-time', 'duration',
        'mute', 'volume', 'captions', 'settings', 'download', 'pip', 'airplay', 'fullscreen'
      ],
      settings: ['speed', 'quality'],
      speed: { selected: 1, options: [0.5, 0.75, 1, 1.25, 1.5, 1.75, 2] },
      seekTime: 10,
      keyboard: { focused: true, global: true },
      tooltips: { controls: true, seek: true },
      invertTime: false,
      resetOnEnd: true,
      displayDuration: true
    };

    document.querySelectorAll('audio.plyr-audio, video.plyr-video').forEach((el) => {
      const id = el.id || `plyr-${Math.random().toString(36).slice(2)}`;
      el.id = id;
      const player = new Plyr(el, plyrConfig);
      plyrInstances.set(id, player);
    });

    document.querySelectorAll('[data-playlist-select]').forEach((select) => {
      const wrapper = select.parentElement;
      if (!wrapper) return;
      const audioEl = wrapper.querySelector('[data-playlist-player]');
      if (!audioEl) return;
      const id = audioEl.id;

      select.addEventListener('change', () => {
        const src = select.value;
        if (id && plyrInstances.has(id)) {
          const player = plyrInstances.get(id);
          player.source = {
            type: 'audio',
            sources: [{ src, type: 'audio/mp3' }]
          };
          player.play();
        } else {
          audioEl.src = src;
          audioEl.load();
          audioEl.play();
        }
      });
    });
  });
</script>

