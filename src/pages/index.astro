      <!-- Strip Lightbox -->
      <div class="strip-lightbox" id="strip-lightbox">
        <button class="strip-lightbox-close" id="lb-close">&times;</button>
        <div class="strip-lightbox-content">
          <button class="strip-lightbox-nav" id="lb-prev">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
          </button>
          <div class="strip-lightbox-image-wrap">
            <img id="lb-img" src="" alt="" />
