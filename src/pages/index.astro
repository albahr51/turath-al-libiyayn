---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import mediaMappings from '../data/media-mappings.json';
import allQuotes from '../data/extracted-quotes.json';
import '../styles/landing.css'; // Global index landing styles

const homepageMedia = mediaMappings.homepage;
---

<Layout title="الأعمال الكاملة للشيخين الشهيدين أبي يحيى وعطية الله الليبيين" description="الموسوعة العلمية الشاملة لأعمال الشيخين الشهيدين أبي يحيى الليبي وعطية الله الليبي - كتب، أبحاث، محاضرات، ومواد صوتية ومرئية">
  <Header />
  
  <main class="single-layout">
    <section class="hero-section fade-in">
      <div class="hero-pattern"></div>
      <div class="hero-mountains"></div>
      <div class="hero-container">
        <div class="portal-badge">الأعمال الكاملة لمشايخ الجهاد</div>
        <h1 class="hero-title">تراث الشيخين أبي يحيى وعطية الله الليبيَّيْن</h1>
        <p class="hero-subtitle">مجموع الأعمال الكاملة للشيخ الشهيد أبي يحيى الليبي والشيخ الشهيد عطية الله الليبي تقبلهما الله</p>
        <p class="hero-compiler">جمع وترتيب: أبي عبد الرحمن الزبير الغزي</p>
        
        <div class="hero-covers">
          <a href="/book/abu-yahya/" class="cover-card">
            <img src="/media/cover_1.png" alt="غلاف مجموع أعمال الشيخ أبي يحيى الليبي" class="cover-img" />
            <span class="cover-label">مجموع أعمال الشيخ أبي يحيى الليبي</span>
          </a>
          <a href="/book/atiyatullah/" class="cover-card">
            <img src="/media/cover_2.png" alt="غلاف مجموع أعمال الشيخ عطية الله الليبي" class="cover-img" />
            <span class="cover-label">مجموع أعمال الشيخ عطية الله الليبي</span>
          </a>
        </div>
        
        <div class="hero-divider"></div>
      </div>
    </section>

    <div class="content-wrapper">
      <!-- Combined Stats bar -->
      <section class="combined-stats fade-in">
        <div class="stat-bubble">
          <span class="stat-num">5569+</span>
          <span class="stat-label">صفحة تحوي خلاصة التراث الجهادي المعاصر</span>
        </div>
        <div class="stat-bubble">
          <span class="stat-num">1019+</span>
          <span class="stat-label">أبواب وفصول منوعة في كافة المسائل الشرعية</span>
        </div>
        <div class="stat-bubble">
          <span class="stat-num">145+</span>
          <span class="stat-label">مادة علمية مرئية ومسموعة مفرغة نصيا</span>
        </div>
        <div class="stat-bubble">
          <span class="stat-num">100%</span>
          <span class="stat-label">تنسيق ورقي دقيق موافق للمطبوع</span>
        </div>
      </section>

      <div class="photo-strip">
        <div class="strip-track" id="strip-track">
          <div class="strip-item" data-src="/media/2.png" data-name="أبو يحيى الليبي" data-bio="/biography/abu-yahya">
            <img src="/media/2.png" alt="أبو يحيى الليبي" loading="lazy" />
            <div class="strip-item-overlay"><span>أبو يحيى الليبي</span></div>
